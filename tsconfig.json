{
  "compilerOptions": {
    "types": ["node"],
    "target": "ESNext",                        // modern JavaScript output
    "module": "ESNext",                        // Vite uses ES modules
    "jsx": "react-jsx",                        // for React 17+ JSX transform
    "strict": true,                            // enable all strict type checks
    "moduleResolution": "Node",               // how modules are resolved
    "esModuleInterop": true,                   // allow default imports from CommonJS
    "forceConsistentCasingInFileNames": true,  // avoid filename case bugs
    "skipLibCheck": true,                      // skip type checks in node_modules
    "resolveJsonModule": true,                 // allow importing JSON files
    "isolatedModules": true,                   // needed for Vite and fast refresh
    "noEmit": true                             // don’t actually compile .ts files
  },
  "include": ["client/src"]                            // what folders to include
}